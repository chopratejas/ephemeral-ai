# DigitalOcean API Token (generate at cloud.digitalocean.com > API > Personal Access Tokens)
DIGITALOCEAN_API_TOKEN=dop_v1_xxxxxxxxxxxx

# DigitalOcean Spaces (generate at cloud.digitalocean.com > API > Spaces Keys)
SPACES_KEY=DOxxxxxxxxxxxxxxxx
SPACES_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SPACES_BUCKET=ephemeral-ai
SPACES_REGION=sfo3

# Gradient AI Model Access Key (generate at cloud.digitalocean.com > Gradient AI)
GRADIENT_MODEL_ACCESS_KEY=dg_xxxxxxxxxxxxxxxx

# Orchestrator settings
ORCHESTRATOR_URL=http://localhost:8000
MAX_CONCURRENT_DROPLETS=5
MAX_DROPLET_AGE_MINUTES=55
DAILY_BUDGET_USD=5.00
